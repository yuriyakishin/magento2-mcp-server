{
    "name": "yuriyakishin/module-mcp-server",
    "description": "Connect Claude and other MCP clients to your Magento 2 store: 40+ MCP tools and 10 guided prompts for catalog, orders, CMS, reviews and sales analytics — secured by OAuth 2.1 + PKCE and native Magento ACL",
    "type": "magento2-module",
    "license": "MIT",
    "keywords": [
        "magento",
        "magento2",
        "mcp",
        "mcp-server",
        "model-context-protocol",
        "claude",
        "ai",
        "ai-agents",
        "llm",
        "ecommerce",
        "oauth2",
        "json-rpc"
    ],
    "authors": [
        {
            "name": "Yuriy Akishin",
            "email": "yuriy.akishin@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/yuriyakishin/magento2-mcp-server/issues",
        "source": "https://github.com/yuriyakishin/magento2-mcp-server"
    },
    "require": {
        "php": "^8.1",
        "magento/framework": "^103.0.4",
        "magento/module-authorization": "^100.4.4",
        "magento/module-backend": "^102.0.4",
        "magento/module-catalog": "^104.0.4",
        "magento/module-catalog-inventory": "^100.4.4",
        "magento/module-cms": "^104.0.4",
        "magento/module-cron": "^100.4.4",
        "magento/module-customer": "^103.0.4",
        "magento/module-indexer": "^100.4.4",
        "magento/module-quote": "^101.2.4",
        "magento/module-reports": "^100.4.4",
        "magento/module-review": "^100.4.4",
        "magento/module-sales": "^103.0.4",
        "magento/module-sales-rule": "^101.2.4",
        "magento/module-search": "^101.1.4",
        "magento/module-store": "^101.1.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Yu\\McpServer\\": ""
        }
    }
}
