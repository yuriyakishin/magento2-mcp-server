{
    "name": "yu/module-mcp-server",
    "description": "MCP (Model Context Protocol) server for Magento 2 — exposes catalog, orders, CMS, reviews and sales analytics as typed, ACL-gated MCP tools over Streamable HTTP with OAuth 2.1 + PKCE login (claude.ai Connectors, Claude Desktop and other MCP clients)",
    "type": "magento2-module",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": [
        "magento2",
        "mcp",
        "model-context-protocol",
        "ai",
        "claude",
        "llm",
        "oauth",
        "json-rpc"
    ],
    "authors": [
        {
            "name": "Yuriy Akishin",
            "email": "yuriy.akishin@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "magento/framework": ">=103.0.4 <104.0",
        "magento/module-authorization": "*",
        "magento/module-backend": "*",
        "magento/module-catalog": "*",
        "magento/module-catalog-inventory": "*",
        "magento/module-cms": "*",
        "magento/module-cron": "*",
        "magento/module-customer": "*",
        "magento/module-indexer": "*",
        "magento/module-quote": "*",
        "magento/module-reports": "*",
        "magento/module-review": "*",
        "magento/module-sales": "*",
        "magento/module-sales-rule": "*",
        "magento/module-search": "*",
        "magento/module-store": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "Yu\\McpServer\\": ""
        }
    }
}
