<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="mcp_oauth_client" resource="default" engine="innodb" comment="MCP OAuth Registered Clients">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="varchar" name="client_id" nullable="false" length="64" comment="Client ID"/>
        <column xsi:type="varchar" name="client_name" nullable="true" length="255" comment="Client Name"/>
        <column xsi:type="text" name="redirect_uris" nullable="false" comment="Allowed Redirect URIs, one per line"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false"
                default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="MCP_OAUTH_CLIENT_CLIENT_ID">
            <column name="client_id"/>
        </constraint>
    </table>

    <table name="mcp_oauth_auth_code" resource="default" engine="innodb" comment="MCP OAuth Authorization Codes">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="varchar" name="code" nullable="false" length="128" comment="Authorization Code"/>
        <column xsi:type="varchar" name="client_id" nullable="false" length="64" comment="Client ID"/>
        <column xsi:type="int" name="admin_user_id" unsigned="true" nullable="false" comment="Admin User ID"/>
        <column xsi:type="varchar" name="code_challenge" nullable="false" length="128" comment="PKCE Code Challenge"/>
        <column xsi:type="varchar" name="code_challenge_method" nullable="false" length="16" default="S256"
                comment="PKCE Code Challenge Method"/>
        <column xsi:type="varchar" name="redirect_uri" nullable="false" length="255" comment="Redirect URI"/>
        <column xsi:type="timestamp" name="expires_at" nullable="false" comment="Expires At"/>
        <column xsi:type="timestamp" name="used_at" nullable="true" comment="Used At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="MCP_OAUTH_AUTH_CODE_CODE">
            <column name="code"/>
        </constraint>
    </table>

    <table name="mcp_oauth_token" resource="default" engine="innodb" comment="MCP OAuth Access/Refresh Tokens">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="varchar" name="access_token" nullable="false" length="128" comment="Access Token"/>
        <column xsi:type="varchar" name="refresh_token" nullable="true" length="128" comment="Refresh Token"/>
        <column xsi:type="varchar" name="client_id" nullable="false" length="64" comment="Client ID"/>
        <column xsi:type="int" name="admin_user_id" unsigned="true" nullable="false" comment="Admin User ID"/>
        <column xsi:type="timestamp" name="expires_at" nullable="false" comment="Access Token Expires At"/>
        <column xsi:type="timestamp" name="revoked_at" nullable="true" comment="Revoked At"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false"
                default="CURRENT_TIMESTAMP" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="MCP_OAUTH_TOKEN_ACCESS_TOKEN">
            <column name="access_token"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="MCP_OAUTH_TOKEN_REFRESH_TOKEN">
            <column name="refresh_token"/>
        </constraint>
    </table>
</schema>
